# Base de données MySQL (Railway en génère une automatiquement)
DATABASE_URL=mysql://user:password@host:3306/dbname

# Clé secrète pour les sessions JWT (générer avec: openssl rand -hex 32)
JWT_SECRET=change-me-with-a-long-random-string

# Google Gemini API Key (obtenir sur https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Dossier de stockage des fichiers uploadés
UPLOAD_DIR=./uploads

# Port du serveur (Railway le configure automatiquement)
PORT=3000

NODE_ENV=production
